

        <div class="auth-container">
            <h2>Login</h2>
            <p>Please log in to manage your OPNsense firewall rules.</p>

            <% include('partials/_flash_messages') %> <% /* Flash messages will be rendered here if any */ %>

            <form action="/auth/login" method="POST" class="auth-form">
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" required>
                </div>
                <button type="submit" class="button">Login</button>
            </form>

            <% if (is_google_oauth_configured) { %>
                <p class="or-separator"><span>OR</span></p>
                <a href="/auth/google" class="button google-login-button">
                    <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google logo" width="20" height="20" style="vertical-align: middle; margin-right: 8px;">
                    Login with Google
                </a>
            <% } else { %>
                <p class="alert alert-warning" style="margin-top: 15px;">Login with Google is currently disabled due to server configuration.</p>
            <% } %>

            <p class="auth-switch-link">
                Don't have an account? <a href="/auth/register">Register here</a>
            </p>
            
            <hr style="margin-top: 30px; margin-bottom: 20px;">
            <h4>Configuration Status Overview:</h4>
            <p><small>This section is for diagnostic purposes.</small></p>
            <%- include('partials/_config_status') %>
        </div>
        <style>
            .auth-container { text-align: center; max-width: 400px; margin: 30px auto; padding: 20px; border: 1px solid #ddd; border-radius: 8px; background-color: #fff; box-shadow: 0 0 10px rgba(0,0,0,0.05); }
            .auth-form .form-group { margin-bottom: 15px; text-align: left; }
            .auth-form label { display: block; margin-bottom: 5px; font-weight: bold; }
            .auth-form input[type="email"], .auth-form input[type="password"], .auth-form input[type="text"] { width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; }
            .auth-form button { width: 100%; padding: 12px; font-size: 1.1em; }
            .google-login-button { display: inline-block; margin-top: 10px; padding: 10px 20px; font-size: 1em; background-color: #4285F4; color: white; border: none; border-radius: 4px; text-decoration: none; }
            .google-login-button img { margin-right: 10px; vertical-align: middle; }
            .or-separator { display: flex; align-items: center; text-align: center; margin: 20px 0; }
            .or-separator span { padding: 0 10px; background-color: #fff; color: #888; }
            .or-separator::before, .or-separator::after { content: ''; flex: 1; border-bottom: 1px solid #ccc; }
            .auth-switch-link { margin-top: 20px; }
        </style>
