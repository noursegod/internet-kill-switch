<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle || 'Admin - Invitations' %></title>
    <!-- Link to a shared stylesheet or add styles here -->
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; }
        .used { color: #aaa; text-decoration: line-through; }
        .unused { color: #008000; font-weight: bold; }
        .button { padding: 10px 15px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer; text-decoration: none; }
        .button:hover { background-color: #0056b3; }
        .message { padding: 10px; margin-bottom: 15px; border-radius: 4px; }
        .success { background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
        .error { background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    </style>
</head>
<body>
    <%- include('partials/_navbar') %> <!-- Assuming a navbar partial -->

    <h1>Admin: Manage Invitation Codes</h1>

    <% if (typeof messages !== 'undefined' && messages.error) { %>
        <div class="message error"><%= messages.error %></div>
    <% } %>
    <% if (typeof messages !== 'undefined' && messages.success) { %>
        <div class="message success"><%= messages.success %></div>
    <% } %>

    <h2>Generate New Invitation</h2>
    <form action="/admin/invitations/create" method="POST">
        <button type="submit" class="button">Generate New Code</button>
    </form>

    <h2>Existing Invitation Codes</h2>
    <% if (invitations && invitations.length > 0) { %>
        <table>
            <thead>
                <tr>
                    <th>Code</th>
                    <th>Status</th>
                    <th>Created At</th>
                    <th>Created By (Email)</th>
                    <th>Used By (User ID)</th>
                </tr>
            </thead>
            <tbody>
                <% invitations.forEach(function(inv) { %>
                    <tr>
                        <td class="<%= inv.is_used ? 'used' : 'unused' %>"><%= inv.code %></td>
                        <td class="<%= inv.is_used ? 'used' : 'unused' %>">
                            <%= inv.is_used ? 'Used' : 'Available' %>
                        </td>
                        <td><%= new Date(inv.created_at).toLocaleString() %></td>
                        <td><%= inv.created_by_email || (inv.created_by_user_id ? 'Admin ID: ' + inv.created_by_user_id : 'N/A') %></td>
                        <td><%= inv.used_by_user_id || 'N/A' %></td>
                    </tr>
                <% }); %>
            </tbody>
        </table>
    <% } else { %>
        <p>No invitation codes found.</p>
    <% } %>

    <p><a href="/">Back to Home</a></p>

</body>
</html>
