<% include layout { 
    pageTitle: pageTitle || 'Manage Schedules', 
    user: user, 
    currentPath: currentPath,
    messages: messages, // Assuming messages are passed from the route
    queryMessages: queryMessages // Assuming queryMessages are passed
} %>

        <div class="schedules-container">
            <h2>Rule Schedules</h2>

            <% if (!is_opnsense_fully_configured) { %>
                <p class="alert alert-warning">
                    OPNsense API is not fully configured on the server. Scheduled actions may fail. 
                    Please contact the administrator.
                </p>
            <% } %>

            <section id="add-schedule">
                <h3>Add New Schedule</h3>
                <form action="/schedules/create" method="POST" class="form-inline">
                    <div class="form-group">
                        <label for="managed_rule_id">Rule to Schedule:</label>
                        <select name="managed_rule_id" id="managed_rule_id" required>
                            <option value="">-- Select a Managed Rule --</option>
                            <% if (typeof managedRules !== 'undefined' && managedRules.length > 0) { %>
                                <% managedRules.forEach(function(rule) { %>
                                    <option value="<%= rule.id %>">
                                        <%= rule.description || rule.opnsense_rule_uuid %> (UUID: <%= rule.opnsense_rule_uuid.substring(0,8) %>...)
                                    </option>
                                <% }); %>
                            <% } else { %>
                                <option value="" disabled>No managed rules available</option>
                            <% } %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="cron_expression">Cron Expression (UTC):</label>
                        <input type="text" name="cron_expression" id="cron_expression" placeholder="e.g., 0 9 * * MON-FRI" required>
                        <small><a href="https://crontab.guru/" target="_blank" rel="noopener noreferrer">Cron Help</a></small>
                    </div>
                    <div class="form-group">
                        <label for="action_to_perform">Action:</label>
                        <select name="action_to_perform" id="action_to_perform" required>
                            <option value="enable">Enable Rule</option>
                            <option value="disable">Disable Rule</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="is_enabled_checkbox">
                            <input type="checkbox" id="is_enabled_checkbox" name="is_enabled" value="on" checked>
                            Schedule Enabled
                        </label>
                    </div>
                    <button type="submit" class="button button-primary">Add Schedule</button>
                </form>
            </section>

            <hr style="margin-top: 30px; margin-bottom: 30px;">

            <section id="existing-schedules">
                <h3>Existing Schedules</h3>
                <% if (schedules && schedules.length > 0) { %>
                    <table>
                        <thead>
                            <tr>
                                <th>Rule Description</th>
                                <th>Rule UUID</th>
                                <th>Cron (UTC)</th>
                                <th>Action</th>
                                <th>Status</th>
                                <th>Last Triggered (UTC)</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% schedules.forEach(function(schedule) { %>
                                <tr>
                                    <td><%= schedule.managed_rule_description || 'N/A' %></td>
                                    <td><small><%= schedule.opnsense_rule_uuid %></small></td>
                                    <td><%= schedule.cron_expression %></td>
                                    <td><%= schedule.action_to_perform.charAt(0).toUpperCase() + schedule.action_to_perform.slice(1) %></td>
                                    <td>
                                        <% if (schedule.is_enabled) { %>
                                            <span class="status-enabled">Active</span>
                                        <% } else { %>
                                            <span class="status-disabled">Paused</span>
                                        <% } %>
                                    </td>
                                    <td><%= schedule.last_triggered_at ? new Date(schedule.last_triggered_at).toLocaleString() : 'Never' %></td>
                                    <td>
                                        <form action="/schedules/<%= schedule.id %>/toggle" method="POST" style="display: inline;">
                                            <button type="submit" class="button button-small">
                                                <%= schedule.is_enabled ? 'Pause' : 'Resume' %>
                                            </button>
                                        </form>
                                        <form action="/schedules/<%= schedule.id %>/delete" method="POST" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this schedule?');">
                                            <button type="submit" class="button-danger button-small">Delete</button>
                                        </form>
                                        <!-- Edit button can be added later -->
                                        <!-- <a href="/schedules/<%= schedule.id %>/edit" class="button button-small button-warning">Edit</a> -->
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                <% } else { %>
                    <p>No schedules found. You can add one using the form above.</p>
                <% } %>
            </section>
        </div>
