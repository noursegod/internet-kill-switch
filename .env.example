PORT=3000
DATABASE_PATH=./instance/opnsense_controller.sqlite

# Session Management
SESSION_SECRET=a_very_strong_random_secret_string_please_change_me_for_production
# Consider also:
APP_BASE_URL=http://localhost:3000 # Important for OAuth callback URLs, especially if behind a proxy in production
NODE_ENV=development # Set to 'production' for production


# OPNsense Configuration
# OPNSENSE_BASE_URL=https://your-opnsense-router-ip-or-hostname/api
# OPNSENSE_API_KEY=your_opnsense_api_key
# OPNSENSE_API_SECRET=your_opnsense_api_secret
# OPNSENSE_IGNORE_CERT_ERRORS="false" # Set to "true" to disable SSL certificate validation for OPNsense API calls. WARNING: Insecure, for development/testing only.

# Google OAuth Configuration
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID_HERE.apps.googleusercontent.com" # Replace with your actual Client ID
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET_HERE" # Replace with your actual Client Secret

# Session Secret (ensure this is a strong, random string in production)
# SESSION_SECRET=a_very_strong_random_secret_string_please_change_me_for_production # Already added, just ensure it's documented

# Invitation System Secret (optional, for signing/verifying something if needed)
# INVITATION_KEY_SECRET=another_strong_random_secret_please_change_me

# Optional: Pre-seed admin Google ID (useful if OOBE first-user-is-admin is problematic, or for deterministic admin setup)
ADMIN_USER_GOOGLE_ID="the_google_id_of_the_predefined_admin_user" # e.g., "10298...."
